# Database credentials
DB_USER=app
DB_PASSWORD=secret
DB_HOST=localhost
DB_PORT=3306
DB_NAME=peercast_yp

# PCP (PeerCast Protocol) listen port
PCP_PORT=7144
# Internal HTTP listen port (Caddy forwards to this)
HTTP_PORT=80

# Domain name used by Caddy for TLS and virtual hosting
SITE_DOMAIN=yayaue.me
# URL path prefix for YP endpoints (e.g. "/yp" → /yp/index.txt). Empty string for root.
YP_PATH=/yp
